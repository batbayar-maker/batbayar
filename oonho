const grid = document.getElementById('grid');
const modalWrap = document.getElementById('modalWrap');

function render(data) {
  const n = data.length;
  document.getElementById('countStat').textContent = n;
  document.getElementById('resultLabel').textContent = n + ' үр дүн';
  if (!n) {
    grid.innerHTML = '<div class="empty-state"><div class="empty-icon">🌍</div><div class="empty-text">Хайлтад тохирох улс орон олдсонгүй</div></div>';
    return;
  }
  grid.innerHTML = data.map(c => {
    const idx = countries.indexOf(c);
    const cur = c.currency.match(/\(([^)]+)\)/)?.[1] || '';
    return `<div class="card" onclick="openModal(${idx})">
      <img class="card-flag" src="https://flagcdn.com/w640/${c.code}.png" alt="${c.name}" loading="lazy">
      <div class="card-glass">
        <div>
          <div class="card-top">
            <span class="card-continent">${c.continent}</span>
            <span class="card-code">${cur}</span>
          </div>
          <div class="card-name">${c.name}</div>
          <div class="card-capital"><span>◈</span>${c.capital}</div>
        </div>
        <div class="card-bottom">
          <div class="card-currency"><small>Мөнгөн тэмдэгт</small>${c.currency}</div>
          <div class="card-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg></div>
        </div>
      </div>
    </div>`;
  }).join('');
}

function openModal(idx) {
  const c = countries[idx];
  const url = `https://flagcdn.com/w640/${c.code}.png`;
  document.getElementById('mBg').src = url;
  document.getElementById('mFlag').src = url;
  document.getElementById('mName').textContent = c.name;
  document.getElementById('mContinent').textContent = c.continent;
  document.getElementById('mCapital').textContent = c.capital;
  document.getElementById('mCurrency').textContent = c.currency;
  document.getElementById('mPhone').textContent = c.phone;
  document.getElementById('mDomain').textContent = c.domain;
  document.getElementById('mDesc').textContent = c.desc;
  modalWrap.classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal() {
  modalWrap.classList.remove('open');
  document.body.style.overflow = '';
}

document.getElementById('searchInput').addEventListener('input', e => {
  const v = e.target.value.toLowerCase();
  render(countries.filter(c =>
    c.name.toLowerCase().includes(v) ||
    c.capital.toLowerCase().includes(v) ||
    c.currency.toLowerCase().includes(v) ||
    c.continent.toLowerCase().includes(v)
  ));
});

document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
render(countries);
</script>
</body>
</html>
