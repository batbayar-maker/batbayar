<!DOCTYPE html>
<html lang="mn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Дэлхийн Лавлах</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,600&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #080b10;
  --surface: #0f1419;
  --surface2: #161c24;
  --border: rgba(255,255,255,0.07);
  --gold: #d4a94a;
  --gold2: #f0c96a;
  --silver: #a8b4c0;
  --white: #f0f4f8;
  --accent: #4a90d4;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  font-family: 'Outfit', sans-serif;
  background: var(--bg);
  color: var(--white);
  min-height: 100vh;
  overflow-x: hidden;
}

body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
  opacity: 0.025;
  pointer-events: none;
  z-index: 9999;
}

/* HERO */
.hero {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  padding: 60px 30px 100px;
  text-align: center;
  overflow: hidden;
}

.orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  pointer-events: none;
  animation: orbFloat 12s ease-in-out infinite;
}
.orb1 { width:600px;height:600px;background:radial-gradient(circle,rgba(212,169,74,.18),transparent 70%);top:-150px;left:-100px;animation-delay:0s; }
.orb2 { width:500px;height:500px;background:radial-gradient(circle,rgba(74,144,212,.12),transparent 70%);bottom:-100px;right:-80px;animation-delay:-6s; }
.orb3 { width:300px;height:300px;background:radial-gradient(circle,rgba(212,169,74,.1),transparent 70%);top:50%;left:50%;transform:translate(-50%,-50%);animation-delay:-3s; }

@keyframes orbFloat {
  0%,100%{transform:translate(0,0) scale(1)}
  33%{transform:translate(30px,-20px) scale(1.05)}
  66%{transform:translate(-20px,15px) scale(.97)}
}

.hero-eyebrow {
  font-size:11px;font-weight:600;letter-spacing:.35em;text-transform:uppercase;
  color:var(--gold);margin-bottom:28px;position:relative;
  display:flex;align-items:center;gap:16px;
  opacity:0;animation:fadeUp .8s ease .2s forwards;
}
.hero-eyebrow::before,.hero-eyebrow::after{content:'';width:40px;height:1px;}
.hero-eyebrow::before{background:linear-gradient(90deg,transparent,var(--gold));}
.hero-eyebrow::after{background:linear-gradient(90deg,var(--gold),transparent);}

.hero-title {
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(3.5rem,9vw,8rem);
  font-weight:300;line-height:.95;letter-spacing:-.02em;
  margin-bottom:12px;
  opacity:0;animation:fadeUp .9s ease .4s forwards;
}
.hero-title strong {
  font-weight:700;font-style:italic;
  background:linear-gradient(135deg,var(--gold) 0%,var(--gold2) 50%,#fff 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}

.hero-sub {
  font-size:15px;font-weight:300;color:var(--silver);letter-spacing:.05em;
  margin-bottom:60px;
  opacity:0;animation:fadeUp .9s ease .55s forwards;
}

.search-outer {
  position:relative;width:100%;max-width:560px;
  opacity:0;animation:fadeUp .9s ease .7s forwards;
}
.search-glow {
  position:absolute;inset:-1px;border-radius:50px;
  background:linear-gradient(135deg,var(--gold),var(--accent),var(--gold));
  background-size:200% 200%;animation:gradShift 4s ease infinite;
  opacity:0;transition:opacity .3s;z-index:0;
}
.search-outer:focus-within .search-glow{opacity:1;}
@keyframes gradShift{0%,100%{background-position:0% 50%}50%{background-position:100% 50%}}

.search-inner {
  position:relative;z-index:1;background:var(--surface);
  border-radius:50px;margin:1px;
  display:flex;align-items:center;padding:0 24px;gap:14px;
}
.search-icon{color:var(--gold);flex-shrink:0;}
#searchInput {
  flex:1;background:transparent;border:none;outline:none;
  font-family:'Outfit',sans-serif;font-size:15px;font-weight:300;
  color:var(--white);padding:18px 0;letter-spacing:.03em;
}
#searchInput::placeholder{color:rgba(168,180,192,.4);}

.stats-row {
  display:flex;gap:0;margin-top:48px;
  opacity:0;animation:fadeUp .9s ease .9s forwards;
}
.stat-item{padding:0 32px;text-align:center;position:relative;}
.stat-item+.stat-item::before{content:'';position:absolute;left:0;top:20%;height:60%;width:1px;background:var(--border);}
.stat-num{font-family:'Cormorant Garamond',serif;font-size:2.4rem;font-weight:700;color:var(--gold);line-height:1;margin-bottom:4px;}
.stat-label{font-size:10px;font-weight:500;letter-spacing:.2em;text-transform:uppercase;color:var(--silver);}

.scroll-hint {
  position:absolute;bottom:36px;left:50%;transform:translateX(-50%);
  display:flex;flex-direction:column;align-items:center;gap:8px;
  color:var(--silver);font-size:10px;letter-spacing:.2em;text-transform:uppercase;
  opacity:0;animation:fadeIn 1s ease 1.5s forwards;
}
.scroll-line{width:1px;height:40px;background:linear-gradient(to bottom,var(--gold),transparent);animation:scrollPulse 2s ease-in-out infinite;}
@keyframes scrollPulse{0%,100%{opacity:.4;transform:scaleY(1)}50%{opacity:1;transform:scaleY(1.1)}}

/* MAIN */
.main{max-width:1400px;margin:0 auto;padding:80px 30px 100px;}

.section-header {
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:40px;padding-bottom:20px;border-bottom:1px solid var(--border);
}
.section-label{font-family:'Cormorant Garamond',serif;font-size:1.6rem;font-weight:300;font-style:italic;color:var(--silver);}
.result-count{font-size:12px;font-weight:500;letter-spacing:.15em;text-transform:uppercase;color:var(--gold);background:rgba(212,169,74,.1);border:1px solid rgba(212,169,74,.2);padding:6px 16px;border-radius:20px;}

/* GRID */
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:2px;}

/* CARD */
.card {
  position:relative;overflow:hidden;cursor:pointer;
  background:var(--surface);
  opacity:0;animation:cardReveal .6s ease forwards;
}
.card:nth-child(1){animation-delay:.05s}
.card:nth-child(2){animation-delay:.1s}
.card:nth-child(3){animation-delay:.15s}
.card:nth-child(4){animation-delay:.2s}
.card:nth-child(5){animation-delay:.25s}
.card:nth-child(6){animation-delay:.3s}
@keyframes cardReveal{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}

.card-flag {
  position:absolute;inset:0;width:100%;height:100%;object-fit:cover;
  transition:transform .8s cubic-bezier(.23,1,.32,1),filter .5s;
  filter:brightness(.25) saturate(.6);
}
.card:hover .card-flag{transform:scale(1.08);filter:brightness(.35) saturate(.8);}

.card-glass {
  position:relative;z-index:2;padding:32px 28px;min-height:260px;
  display:flex;flex-direction:column;justify-content:space-between;
  background:linear-gradient(135deg,rgba(15,20,25,.5) 0%,rgba(8,11,16,.3) 100%);
  border:1px solid var(--border);transition:background .4s,border-color .3s;
}
.card:hover .card-glass{
  background:linear-gradient(135deg,rgba(15,20,25,.3) 0%,rgba(8,11,16,.1) 100%);
  border-color:rgba(212,169,74,.2);
}

.card-top{display:flex;align-items:flex-start;justify-content:space-between;gap:12px;}
.card-continent{font-size:9px;font-weight:600;letter-spacing:.3em;text-transform:uppercase;color:var(--gold);background:rgba(212,169,74,.12);border:1px solid rgba(212,169,74,.25);padding:5px 12px;border-radius:3px;}
.card-code{font-family:'Outfit',monospace;font-size:10px;font-weight:600;letter-spacing:.15em;color:var(--silver);background:rgba(255,255,255,.06);padding:5px 10px;border-radius:3px;border:1px solid var(--border);}
.card-name{font-family:'Cormorant Garamond',serif;font-size:2.2rem;font-weight:700;line-height:1;letter-spacing:-.01em;margin:20px 0 6px;transition:color .3s;}
.card:hover .card-name{color:var(--gold2);}
.card-capital{font-size:13px;font-weight:300;color:var(--silver);letter-spacing:.05em;margin-bottom:24px;}
.card-capital span{color:rgba(168,180,192,.5);margin-right:6px;}
.card-bottom{display:flex;align-items:center;justify-content:space-between;padding-top:20px;border-top:1px solid var(--border);}
.card-currency{font-size:12px;font-weight:500;color:var(--white);letter-spacing:.05em;}
.card-currency small{display:block;font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--silver);margin-bottom:2px;font-weight:400;}
.card-arrow{width:36px;height:36px;border-radius:50%;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;color:var(--silver);transition:all .3s;flex-shrink:0;}
.card:hover .card-arrow{border-color:var(--gold);color:var(--gold);background:rgba(212,169,74,.1);transform:translate(2px,-2px);}

/* MODAL */
.modal-wrap{display:none;position:fixed;inset:0;z-index:10000;align-items:center;justify-content:center;padding:20px;}
.modal-wrap.open{display:flex;}
.modal-backdrop{position:absolute;inset:0;background:rgba(4,6,10,.92);backdrop-filter:blur(20px);animation:fadeIn .3s ease;}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}

.modal {
  position:relative;z-index:1;width:100%;max-width:820px;max-height:92vh;overflow-y:auto;
  background:var(--surface);border:1px solid rgba(212,169,74,.2);border-radius:4px;
  animation:modalIn .45s cubic-bezier(.23,1,.32,1);
  scrollbar-width:thin;scrollbar-color:var(--gold) transparent;
}
@keyframes modalIn{from{transform:scale(.92) translateY(40px);opacity:0}to{transform:scale(1) translateY(0);opacity:1}}

.modal-hero{position:relative;height:340px;overflow:hidden;}
.modal-flag-bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:brightness(.3) saturate(.5);transform:scale(1.05);}
.modal-flag-center{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;}
.modal-flag-frame{width:240px;height:150px;border-radius:6px;overflow:hidden;box-shadow:0 30px 80px rgba(0,0,0,.8),0 0 0 1px rgba(255,255,255,.1);position:relative;}
.modal-flag-frame img{width:100%;height:100%;object-fit:cover;}
.modal-flag-shine{position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.15) 0%,transparent 50%);}
.modal-hero-overlay{position:absolute;inset:0;background:linear-gradient(to top,var(--surface) 0%,transparent 60%);}
.modal-close{position:absolute;top:20px;right:20px;width:44px;height:44px;border-radius:50%;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--silver);font-size:20px;transition:all .2s;z-index:10;line-height:1;}
.modal-close:hover{background:rgba(212,169,74,.15);border-color:var(--gold);color:var(--gold);}

.modal-body{padding:40px 44px 48px;}
.modal-title-row{display:flex;align-items:flex-end;justify-content:space-between;gap:20px;margin-bottom:36px;}
.modal-name{font-family:'Cormorant Garamond',serif;font-size:3.2rem;font-weight:700;line-height:1;letter-spacing:-.02em;background:linear-gradient(135deg,var(--white) 0%,var(--gold2) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.modal-continent-badge{font-size:10px;font-weight:600;letter-spacing:.25em;text-transform:uppercase;color:var(--gold);border:1px solid rgba(212,169,74,.3);padding:8px 18px;border-radius:3px;white-space:nowrap;flex-shrink:0;background:rgba(212,169,74,.07);}

.info-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:32px;}
.info-tile{background:var(--surface2);border:1px solid var(--border);border-radius:4px;padding:20px 22px;transition:border-color .2s;}
.info-tile:hover{border-color:rgba(212,169,74,.25);}
.info-tile-icon{font-size:18px;margin-bottom:10px;display:block;}
.info-tile-label{font-size:9px;font-weight:600;letter-spacing:.25em;text-transform:uppercase;color:var(--gold);margin-bottom:6px;}
.info-tile-val{font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:600;color:var(--white);line-height:1.2;}

.modal-divider{height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent);margin-bottom:28px;}
.modal-desc-label{font-size:9px;font-weight:600;letter-spacing:.3em;text-transform:uppercase;color:var(--gold);margin-bottom:14px;}
.modal-desc-text{font-size:15px;font-weight:300;line-height:1.85;color:rgba(240,244,248,.7);letter-spacing:.02em;}
.modal-desc-text::first-letter{font-family:'Cormorant Garamond',serif;font-size:3.5rem;font-weight:700;float:left;line-height:.75;margin-right:10px;margin-top:10px;color:var(--gold);}

/* EMPTY */
.empty-state{grid-column:1/-1;text-align:center;padding:100px 20px;color:var(--silver);}
.empty-icon{font-size:3rem;margin-bottom:16px;opacity:.4;}
.empty-text{font-family:'Cormorant Garamond',serif;font-size:1.6rem;font-style:italic;opacity:.5;}

@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}

@media(max-width:680px){
  .info-grid{grid-template-columns:1fr;}
  .modal-body{padding:28px 24px 36px;}
  .modal-name{font-size:2.2rem;}
  .modal-title-row{flex-direction:column;align-items:flex-start;}
  .stat-item{padding:0 16px;}
  .grid{grid-template-columns:1fr;gap:2px;}
}
</style>
</head>
<body>

<section class="hero">
  <div class="orb orb1"></div>
  <div class="orb orb2"></div>
  <div class="orb orb3"></div>

  <div class="hero-eyebrow">Дэлхийн Нэвтэрхий Толь</div>
  <h1 class="hero-title">Улс<br><strong>Орнуудын</strong><br>Лавлах</h1>
  <p class="hero-sub">Дэлхийн улс орнуудын мэдээлэл, соёл, газарзүйн дэлгэрэнгүй санд тавтай морил</p>

  <div class="search-outer">
    <div class="search-glow"></div>
    <div class="search-inner">
      <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input id="searchInput" type="text" placeholder="Улс, нийслэл, тив хайх…" autocomplete="off">
    </div>
  </div>

  <div class="stats-row">
    <div class="stat-item"><div class="stat-num" id="countStat">6</div><div class="stat-label">Улс орон</div></div>
    <div class="stat-item"><div class="stat-num">4</div><div class="stat-label">Тив</div></div>
    <div class="stat-item"><div class="stat-num">6</div><div class="stat-label">Валют</div></div>
  </div>

  <div class="scroll-hint">
    <div class="scroll-line"></div>
    доош гүйлгэх
  </div>
</section>

<main class="main">
  <div class="section-header">
    <div class="section-label">Бүх улс орнууд</div>
    <div class="result-count" id="resultLabel">6 үр дүн</div>
  </div>
  <div class="grid" id="grid"></div>
</main>

<div class="modal-wrap" id="modalWrap">
  <div class="modal-backdrop" onclick="closeModal()"></div>
  <div class="modal" id="modal">
    <div class="modal-hero">
      <img id="mBg" class="modal-flag-bg" src="" alt="">
      <div class="modal-flag-center">
        <div class="modal-flag-frame">
          <img id="mFlag" src="" alt="">
          <div class="modal-flag-shine"></div>
        </div>
      </div>
      <div class="modal-hero-overlay"></div>
      <button class="modal-close" onclick="closeModal()">&#215;</button>
    </div>
    <div class="modal-body">
      <div class="modal-title-row">
        <h2 class="modal-name" id="mName"></h2>
        <div class="modal-continent-badge" id="mContinent"></div>
      </div>
      <div class="info-grid">
        <div class="info-tile"><span class="info-tile-icon">🏛</span><div class="info-tile-label">Нийслэл</div><div class="info-tile-val" id="mCapital"></div></div>
        <div class="info-tile"><span class="info-tile-icon">💰</span><div class="info-tile-label">Мөнгөн тэмдэгт</div><div class="info-tile-val" id="mCurrency"></div></div>
        <div class="info-tile"><span class="info-tile-icon">📞</span><div class="info-tile-label">Утасны код</div><div class="info-tile-val" id="mPhone"></div></div>
        <div class="info-tile"><span class="info-tile-icon">🌐</span><div class="info-tile-label">Домэйн</div><div class="info-tile-val" id="mDomain"></div></div>
      </div>
      <div class="modal-divider"></div>
      <div class="modal-desc-label">Тухай</div>
      <div class="modal-desc-text" id="mDesc"></div>
    </div>
  </div>
</div>

<script>
const countries = [
  { name:"Монгол", code:"mn", capital:"Улаанбаатар", continent:"Ази", currency:"Төгрөг (MNT)", phone:"+976", domain:".mn", desc:"Төв Азид байрладаг, дэлхийн хамгийн сийрэг хүн амтай улс. Нүүдлийн соёл иргэншил болон уул уурхай дээр суурилсан эдийн засагтай. Монгол нь Чингис хааны байгуулсан дэлхийн хамгийн том газар нутгийг эзэлж байсан эзэнт гүрний өв залгамжлагч юм. Говийн цөл, Хангайн нуруу, тал хээрийн өргөн уудам нутаг нь онцгой байгалийн гайхамшгаар дүүрэн." },
  { name:"Япон", code:"jp", capital:"Токио", continent:"Ази", currency:"Иен (JPY)", phone:"+81", domain:".jp", desc:"Дэлхийн технологийн тэргүүлэгч орнуудын нэг. Өвөрмөц соёл, сахилга бат, урт наслалтаараа алдартай. Сакура цэцэглэх хавар, онигири, суши, аниме болон роботын технологиор дэлхийд танигдсан. 6,000 гаруй арлаас бүрдэх архипелаг улс бөгөөд Фүжи уул нь үндэсний бэлгэдэл болдог." },
  { name:"АНУ", code:"us", capital:"Вашингтон", continent:"Америк", currency:"Доллар (USD)", phone:"+1", domain:".us", desc:"Дэлхийн хамгийн том эдийн засагтай гүрэн. Технологи, энтертайнмент, цэргийн хүчин чадлаараа дэлхийд нөлөөлөгч. Силикон хөндий, Холливуд болон НАСА-гийн гэр оронд нь орно. 50 мужаас бүрдэх холбооны бүгд найрамдах улс бөгөөд дэлхийн хамгийн нөлөө бүхий улс орнуудын нэг юм." },
  { name:"Герман", code:"de", capital:"Берлин", continent:"Европ", currency:"Евро (EUR)", phone:"+49", domain:".de", desc:"Европын Холбооны хамгийн том эдийн засаг. Чанартай инженерчлэл болон автомашин үйлдвэрлэлээрээ дэлхийд танигдсан. BMW, Mercedes-Benz, Volkswagen зэрэг алдарт брэндүүдийн нутаг орон. Бетховен, Гёте, Эйнштейн зэрэг дэлхийд нэр хүндтэй хүмүүсийг төрүүлсэн соёлын баян орон." },
  { name:"Сингапур", code:"sg", capital:"Сингапур", continent:"Ази", currency:"Сингапур Доллар (SGD)", phone:"+65", domain:".sg", desc:"Азийн санхүү, тээврийн хамгийн том зангилаа цэг. Маш цэвэрхэн, аюулгүй, өндөр хөгжилтэй хот улс. Gardens by the Bay болон Marina Bay Sands хоёр дэлхийд алдарт жуулчлалын объект юм. Дэлхийн хамгийн өндөр амьжиргааны түвшинтэй орнуудын нэгд тооцогддог." },
